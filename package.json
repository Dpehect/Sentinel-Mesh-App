{
  "name": "sentinel-mesh",
  "version": "1.6.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:worker",
    "dev:web": "npm run dev -w @sentinel/web",
    "dev:worker": "npm run dev -w @sentinel/worker",
    "build": "npm-run-all build:packages build:apps",
    "build:packages": "npm run build -w @sentinel/security-core && npm run build -w @sentinel/ai-intelligence && npm run build -w @sentinel/enterprise-core && npm run build -w @sentinel/posture-intelligence && npm run build -w @sentinel/plugin-sdk && npm run build -w @sentinel/db && npm run build -w @sentinel/scanner-runner",
    "build:apps": "npm run build -w @sentinel/web && npm run build -w @sentinel/worker",
    "test": "npm-run-all test:core test:intelligence test:enterprise test:posture test:scanner test:worker test:web",
    "test:core": "npm run test -w @sentinel/security-core",
    "test:web": "npm run test -w @sentinel/web",
    "test:posture": "npm run test -w @sentinel/posture-intelligence",
    "typecheck": "npm-run-all typecheck:web typecheck:worker typecheck:core typecheck:intelligence typecheck:enterprise typecheck:posture typecheck:db typecheck:scanner typecheck:plugin-sdk",
    "typecheck:web": "npm run typecheck -w @sentinel/web",
    "typecheck:worker": "npm run typecheck -w @sentinel/worker",
    "typecheck:core": "npm run typecheck -w @sentinel/security-core",
    "typecheck:db": "npm run typecheck -w @sentinel/db",
    "typecheck:posture": "npm run typecheck -w @sentinel/posture-intelligence",
    "lint": "npm-run-all lint:*",
    "lint:web": "npm run lint -w @sentinel/web",
    "lint:worker": "npm run lint -w @sentinel/worker",
    "db:migrate": "npm run migrate -w @sentinel/db",
    "db:seed": "npm run seed -w @sentinel/db",
    "verify": "npm run verify:static && npm run typecheck && npm run test && npm run build",
    "test:worker": "npm run test -w @sentinel/worker",
    "test:scanner": "npm run test -w @sentinel/scanner-runner",
    "test:e2e": "npm run test:e2e -w @sentinel/web",
    "benchmark": "node scripts/benchmark.mjs",
    "release:source": "bash scripts/package-source.sh",
    "typecheck:scanner": "npm run typecheck -w @sentinel/scanner-runner",
    "typecheck:plugin-sdk": "npm run typecheck -w @sentinel/plugin-sdk",
    "verify:static": "node scripts/static-verify.mjs",
    "test:intelligence": "npm run test -w @sentinel/ai-intelligence",
    "typecheck:intelligence": "npm run typecheck -w @sentinel/ai-intelligence",
    "test:enterprise": "npm run test -w @sentinel/enterprise-core",
    "typecheck:enterprise": "npm run typecheck -w @sentinel/enterprise-core"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3"
  }
}
